generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  slug      String   @id
  name      String
  createdAt DateTime @default(now())
  posts     Post[]
}

model Tag {
  name       String   @id
  parentName String?
  parent     Tag?     @relation("TagHierarchy", fields: [parentName], references: [name])
  children   Tag[]    @relation("TagHierarchy")
  createdAt  DateTime @default(now())
  posts      Post[]
}

model Post {
  slug        String             @id
  title       String
  content     String             @db.Text
  summary     String?            @db.Text
  category    String
  categoryRef Category           @relation(fields: [category], references: [slug])
  tagRefs     Tag[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime?
  views       Int                @default(0)
  reactions   String?
  coverImage  String?
  images      String?
  source      String             @default("manual")
  sourceUrl   String?
  comments    Comment[]
  relatedFrom PostRelationship[] @relation("SourcePost")
  relatedTo   PostRelationship[] @relation("TargetPost")
  readBy      PostReadHistory[]

  @@index([category])
  @@index([createdAt(sort: Desc)])
}

model Comment {
  id         String   @id
  postSlug   String
  post       Post     @relation(fields: [postSlug], references: [slug], onDelete: Cascade)
  authorName String
  content    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([postSlug])
}

model DeviceSession {
  id         String   @id @default(cuid())
  cookieId   String   @unique
  ip         String?
  userAgent  String?
  os         String?
  device     String?
  browser    String?
  country    String?
  city       String?
  timezone   String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @updatedAt
  readPosts  PostReadHistory[]

  @@index([cookieId])
}

model PostReadHistory {
  id        String        @id @default(cuid())
  sessionId String
  postSlug  String
  readAt    DateTime      @default(now())
  session   DeviceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  post      Post          @relation(fields: [postSlug], references: [slug], onDelete: Cascade)

  @@unique([sessionId, postSlug])
  @@index([sessionId])
  @@index([postSlug])
}

model PostRelationship {
  id          String   @id @default(uuid())
  sourceSlug  String
  sourcePost  Post     @relation("SourcePost", fields: [sourceSlug], references: [slug], onDelete: Cascade)
  targetSlug  String
  targetPost  Post     @relation("TargetPost", fields: [targetSlug], references: [slug], onDelete: Cascade)
  score       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sourceSlug, targetSlug])
  @@index([sourceSlug])
  @@index([targetSlug])
}

