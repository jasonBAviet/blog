    "@tiptap/extension-placeholder": "^3.23.1",
    "@tiptap/react": "^3.23.1",
    "@tiptap/starter-kit": "^3.23.1",
    "d3": "^7.9.0",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.9.0",
    "framer-motion": "^11.0.0",
    "next": "^15.0.0",
    "next-themes": "^0.4.0",
    "pg": "^8.21.0",
