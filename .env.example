# Admin
ADMIN_PASSWORD=your_admin_password_here

# Blog DB (PostgreSQL) — dedicated database
DATABASE_URL="postgresql://username:password@localhost:5432/blog"
DIRECT_URL="postgresql://username:password@localhost:5432/blog"

# API key cho hệ thống nạp bài tự động — thay bằng chuỗi ngẫu nhiên mạnh khi deploy
INGEST_API_KEY="your_ingest_api_key_here"

# Base credentials (shared)
SSH_HOST=127.0.0.1
SSH_PORT=22
SSH_USER=root
SSH_PASSWORD=your_ssh_password_here
SSH_PASS=your_ssh_password_here

# PostgreSQL Database Configuration
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=blog
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_PASS=your_db_password_here
